+
+    def _get_reward_components(
+        self,
+        data: mjx.Data,
+        action: jax.Array,
+        previous_action: jax.Array,
+        info: dict,
+    ) -> dict[str, jax.Array]:
+        """Izracunaj reward i eval metrike jednim prolazom kroz hot path."""
+        local_linvel = self._local_root_linvel(data)

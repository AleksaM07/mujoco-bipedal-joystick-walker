{
  "env": {
    "env_source": "biomechanics",
    "env_version": "standard",
    "playground_impl": "jax",
    "prototype_flat_env": "BerkeleyHumanoidJoystickFlatTerrain",
    "prototype_hardcore_env": "BerkeleyHumanoidJoystickRoughTerrain",
    "command_change_rate": 0.1,
    "command_profile": "forward",
    "reference_gait": "bvh",
    "reference_gait_file": null,
    "reference_target_observation": true,
    "reference_phase_randomization": false,
    "reference_state_init": false,
    "xml_path": null,
    "legacy_action_prior": false,
    "action_smoothing": 0.5,
    "init_qpos_file": null,
    "accurate_physics": true
  },
  "train": {
    "seed": 7,
    "num_timesteps": 1000000,
    "num_evals": 10,
    "num_envs": 512,
    "num_eval_envs": 16,
    "episode_length": null,
    "unroll_length": null,
    "batch_size": 256,
    "num_minibatches": null,
    "num_updates_per_batch": null,
    "learning_rate": null,
    "no_erfi": true,
    "no_domain_randomization": true,
    "save_checkpoints": true,
    "checkpoint_out": null,
    "resume_from": null,
    "run_tag": "reward_fix_1m_diag",
    "diagnostic_rollout": true,
    "diagnostic_rollout_steps": 20,
    "debug_run": false,
    "bare": false,
    "algorithm": "ppo"
  },
  "brax_ppo": {
    "action_repeat": 1,
    "batch_size": 256,
    "clipping_epsilon": 0.2,
    "discounting": 0.97,
    "entropy_cost": 0.003,
    "episode_length": 500,
    "gae_lambda": 0.95,
    "learning_rate": 0.0003,
    "max_grad_norm": 1.0,
    "network_factory": {
      "activation": "jax._src.nn.functions.silu",
      "policy_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "policy_obs_key": "state",
      "value_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "value_obs_key": "privileged_state"
    },
    "normalize_observations": true,
    "normalize_observations_std_eps": 0.001,
    "num_envs": 512,
    "num_eval_envs": 16,
    "num_evals": 10,
    "num_minibatches": 8,
    "num_timesteps": 1000000,
    "num_updates_per_batch": 4,
    "reward_scaling": 1.0,
    "unroll_length": 20,
    "network_factory_fn": "brax.training.agents.ppo.networks.make_ppo_networks"
  }
}
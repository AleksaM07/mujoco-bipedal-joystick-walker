{
  "env": {
    "env_source": "biomechanics",
    "env_version": "standard",
    "playground_impl": "jax",
    "prototype_flat_env": "BerkeleyHumanoidJoystickFlatTerrain",
    "prototype_hardcore_env": "BerkeleyHumanoidJoystickRoughTerrain",
    "command_change_rate": 0.1,
    "command_profile": "forward",
    "action_smoothing": 0.5,
    "accurate_physics": true
  },
  "train": {
    "seed": 7,
    "num_timesteps": 10000000,
    "num_evals": 10,
    "num_envs": 512,
    "episode_length": 400,
    "unroll_length": null,
    "batch_size": null,
    "num_minibatches": null,
    "num_updates_per_batch": null,
    "learning_rate": null,
    "no_domain_randomization": false,
    "debug_run": false,
    "bare": true,
    "algorithm": "ppo"
  },
  "brax_ppo": {
    "action_repeat": 1,
    "batch_size": 256,
    "clipping_epsilon": 0.2,
    "discounting": 0.97,
    "entropy_cost": 0.0001,
    "episode_length": 400,
    "gae_lambda": 0.95,
    "learning_rate": 0.0001,
    "max_grad_norm": 1.0,
    "network_factory": {
      "activation": "jax._src.nn.functions.silu",
      "policy_hidden_layer_sizes": [
        256,
        128
      ],
      "value_hidden_layer_sizes": [
        256,
        128
      ]
    },
    "normalize_observations": true,
    "normalize_observations_std_eps": 0.001,
    "num_envs": 512,
    "num_eval_envs": 16,
    "num_evals": 10,
    "num_minibatches": 4,
    "num_timesteps": 10000000,
    "num_updates_per_batch": 2,
    "reward_scaling": 1.0,
    "unroll_length": 10,
    "network_factory_fn": "brax.training.agents.ppo.networks.make_ppo_networks"
  }
}
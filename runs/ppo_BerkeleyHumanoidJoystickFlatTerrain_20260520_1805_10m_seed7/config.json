{
  "env": {
    "env_version": "standard",
    "playground_impl": "jax",
    "playground_flat_env": "BerkeleyHumanoidJoystickFlatTerrain",
    "playground_hardcore_env": "BerkeleyHumanoidJoystickRoughTerrain",
    "command_change_rate": 0.1
  },
  "train": {
    "seed": 7,
    "num_timesteps": 10000000,
    "num_evals": 5,
    "num_envs": 1024,
    "batch_size": null,
    "learning_rate": null,
    "algorithm": "ppo"
  },
  "brax_ppo": {
    "action_repeat": 1,
    "batch_size": 256,
    "clipping_epsilon": 0.2,
    "discounting": 0.97,
    "entropy_cost": 0.005,
    "episode_length": 1000,
    "learning_rate": 0.0003,
    "max_grad_norm": 1.0,
    "network_factory": {
      "policy_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "policy_obs_key": "state",
      "value_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "value_obs_key": "privileged_state"
    },
    "normalize_observations": true,
    "num_envs": 1024,
    "num_evals": 5,
    "num_minibatches": 32,
    "num_resets_per_eval": 10,
    "num_timesteps": 10000000,
    "num_updates_per_batch": 4,
    "reward_scaling": 1.0,
    "unroll_length": 20,
    "network_factory_fn": "brax.training.agents.ppo.networks.make_ppo_networks"
  }
}
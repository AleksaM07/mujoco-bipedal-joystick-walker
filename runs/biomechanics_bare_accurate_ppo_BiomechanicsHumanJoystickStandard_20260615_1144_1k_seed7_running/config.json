{
  "env": {
    "env_source": "biomechanics",
    "env_version": "standard",
    "playground_impl": "jax",
    "prototype_flat_env": "BerkeleyHumanoidJoystickFlatTerrain",
    "prototype_hardcore_env": "BerkeleyHumanoidJoystickRoughTerrain",
    "command_change_rate": 0.1,
    "command_profile": "standard",
    "action_smoothing": 0.5,
    "init_qpos_file": null,
    "accurate_physics": true
  },
  "train": {
    "seed": 7,
    "num_timesteps": 1000,
    "num_evals": 0,
    "num_envs": 4,
    "episode_length": 20,
    "unroll_length": 5,
    "batch_size": 4,
    "num_minibatches": 1,
    "num_updates_per_batch": 1,
    "learning_rate": null,
    "no_erfi": false,
    "no_domain_randomization": true,
    "save_checkpoints": false,
    "checkpoint_out": null,
    "resume_from": null,
    "debug_run": true,
    "bare": true,
    "algorithm": "ppo"
  },
  "brax_ppo": {
    "action_repeat": 1,
    "batch_size": 4,
    "clipping_epsilon": 0.2,
    "discounting": 0.97,
    "entropy_cost": 0.003,
    "episode_length": 20,
    "gae_lambda": 0.95,
    "learning_rate": 0.0003,
    "max_grad_norm": 1.0,
    "network_factory": {
      "activation": "jax._src.nn.functions.silu",
      "policy_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "policy_obs_key": "state",
      "value_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "value_obs_key": "privileged_state"
    },
    "normalize_observations": true,
    "normalize_observations_std_eps": 0.001,
    "num_envs": 4,
    "num_eval_envs": 32,
    "num_evals": 0,
    "num_minibatches": 1,
    "num_timesteps": 1000,
    "num_updates_per_batch": 1,
    "reward_scaling": 1.0,
    "unroll_length": 5,
    "network_factory_fn": "brax.training.agents.ppo.networks.make_ppo_networks"
  }
}